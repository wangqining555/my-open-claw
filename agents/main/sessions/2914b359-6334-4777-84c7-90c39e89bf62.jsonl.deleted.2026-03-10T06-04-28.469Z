{"type":"message","id":"0b814465","parentId":"b55f30cc","timestamp":"2026-02-19T08:24:56.243Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now create the main screen.","thinkingSignature":"0ba0258ee422fa898628e60a047050c655f003c29b3e4c185b76a4db1bc629d5"},{"type":"toolCall","id":"call_function_11k8gfst0u7u_1","name":"write","arguments":{"content":"package com.kidscore.app.ui.screens\n\nimport androidx.compose.animation.animateColorAsState\nimport androidx.compose.animation.core.animateFloatAsState\nimport androidx.compose.foundation.background\nimport androidx.compose.foundation.layout.*\nimport androidx.compose.foundation.rememberScrollState\nimport androidx.compose.foundation.shape.CircleShape\nimport androidx.compose.foundation.shape.RoundedCornerShape\nimport androidx.compose.foundation.verticalScroll\nimport androidx.compose.material.icons.Icons\nimport androidx.compose.material.icons.filled.Clear\nimport androidx.compose.material.icons.filled.Search\nimport androidx.compose.material3.*\nimport androidx.compose.runtime.*\nimport androidx.compose.ui.Alignment\nimport androidx.compose.ui.Modifier\nimport androidx.compose.ui.draw.clip\nimport androidx.compose.ui.graphics.Color\nimport androidx.compose.ui.text.font.FontWeight\nimport androidx.compose.ui.text.style.TextAlign\nimport androidx.compose.ui.unit.dp\nimport androidx.compose.ui.unit.sp\nimport androidx.lifecycle.viewmodel.compose.viewModel\nimport com.kidscore.app.data.model.ParentingBehavior\nimport com.kidscore.app.ui.theme.ScoreHigh\nimport com.kidscore.app.ui.theme.ScoreLow\nimport com.kidscore.app.ui.theme.ScoreMedium\nimport com.kidscore.app.viewmodel.ScoreViewModel\n\n@OptIn(ExperimentalMaterial3Api::class)\n@Composable\nfun ScoreScreen(\n    viewModel: ScoreViewModel = viewModel()\n) {\n    val uiState by viewModel.uiState.collectAsState()\n\n    Scaffold(\n        topBar = {\n            TopAppBar(\n                title = { Text(\"育儿评分\") },\n                colors = TopAppBarDefaults.topAppBarColors(\n                    containerColor = MaterialTheme.colorScheme.primary,\n                    titleContentColor = Color.White\n                )\n            )\n        }\n    ) { paddingValues ->\n        Column(\n            modifier = Modifier\n                .fillMaxSize()\n                .padding(paddingValues)\n                .verticalScroll(rememberScrollState())\n                .padding(16.dp),\n            horizontalAlignment = Alignment.CenterHorizontally\n        ) {\n            // 标题\n            Text(\n                text = \"🔍 输入育儿行为\",\n                style = MaterialTheme.typography.headlineMedium,\n                modifier = Modifier.padding(bottom = 16.dp)\n            )\n\n            // 输入框\n            OutlinedTextField(\n                value = uiState.inputText,\n                onValueChange = viewModel::onInputChange,\n                modifier = Modifier.fillMaxWidth(),\n                placeholder = { Text(\"例如：孩子不吃饭、孩子玩手机、孩子哭闹\") },\n                leadingIcon = {\n                    Icon(Icons.Default.Search, contentDescription = \"搜索\")\n                },\n                trailingIcon = {\n                    if (uiState.inputText.isNotEmpty()) {\n                        IconButton(onClick = { viewModel.clearResult() }) {\n                            Icon(Icons.Default.Clear, contentDescription = \"清除\")\n                        }\n                    }\n                },\n                singleLine = false,\n                maxLines = 3,\n                shape = RoundedCornerShape(12.dp)\n            )\n\n            Spacer(modifier = Modifier.height(16.dp))\n\n            // 搜索按钮\n            Button(\n                onClick = { viewModel.searchBehavior() },\n                modifier = Modifier\n                    .fillMaxWidth()\n                    .height(50.dp),\n                enabled = !uiState.isLoading,\n                shape = RoundedCornerShape(12.dp)\n            ) {\n                if (uiState.isLoading) {\n                    CircularProgressIndicator(\n                        modifier = Modifier.size(24.dp),\n                        color = Color.White\n                    )\n                } else {\n                    Text(\"获取评分\", fontSize = 16.sp)\n                }\n            }\n\n            // 错误提示\n            uiState.errorMessage?.let { error ->\n                Spacer(modifier = Modifier.height(16.dp))\n                Card(\n                    colors = CardDefaults.cardColors(\n                        containerColor = ScoreLow.copy(alpha = 0.1f)\n                    ),\n                    modifier = Modifier.fillMaxWidth()\n                ) {\n                    Text(\n                        text = error,\n                        color = ScoreLow,\n                        modifier = Modifier.padding(16.dp),\n                        textAlign = TextAlign.Center\n                    )\n                }\n            }\n\n            // 显示结果\n            uiState.result?.let { result ->\n                Spacer(modifier = Modifier.height(24.dp))\n                ScoreResultCard(result = result)\n            }\n\n            // 搜索示例提示\n            if (!uiState.hasSearched) {\n                Spacer(modifier = Modifier.height(32.dp))\n                Card(\n                    colors = CardDefaults.cardColors(\n                        containerColor = MaterialTheme.colorScheme.surfaceVariant\n                    ),\n                    modifier = Modifier.fillMaxWidth()\n                ) {\n                    Column(modifier = Modifier.padding(16.dp)) {\n                        Text(\n                            text = \"💡 试试这些关键词\",\n                            style = MaterialTheme.typography.titleMedium,\n                            fontWeight = FontWeight.Bold\n                        )\n                        Spacer(modifier = Modifier.height(8.dp))\n                        Text(\"• 孩子不吃饭、挑食\")\n                        Text(\"• 孩子熬夜、失眠\")\n                        Text(\"• 孩子写作业拖拉\")\n                        Text(\"• 孩子哭闹、发脾气\")\n                        Text(\"• 孩子玩手机、玩游戏\")\n                        Text(\"• 孩子说谎、顶嘴\")\n                    }\n                }\n            }\n        }\n    }\n}\n\n@Composable\nfun ScoreResultCard(result: ParentingBehavior) {\n    val scoreColor by remember(result.score) {\n        mutableStateOf(\n            when {\n                result.score >= 70 -> ScoreHigh\n                result.score >= 50 -> ScoreMedium\n                else -> ScoreLow\n            }\n        )\n    }\n\n    val animatedColor by animateColorAsState(\n        targetValue = scoreColor,\n        label = \"scoreColor\"\n    )\n\n    Card(\n        modifier = Modifier.fillMaxWidth(),\n        shape = RoundedCornerShape(16.dp),\n        elevation = CardDefaults.cardElevation(defaultElevation = 4.dp)\n    ) {\n        Column(\n            modifier = Modifier.padding(20.dp)\n        ) {\n            // 评分圆环\n            Box(\n                modifier = Modifier\n                    .fillMaxWidth()\n                    .padding(vertical = 16.dp),\n                contentAlignment = Alignment.Center\n            ) {\n                ScoreCircle(\n                    score = result.score,\n                    color = animatedColor\n                )\n            }\n\n            // 行为名称\n            Text(\n                text = result.name,\n                style = MaterialTheme.typography.headlineMedium,\n                fontWeight = FontWeight.Bold,\n                textAlign = TextAlign.Center,\n                modifier = Modifier.fillMaxWidth()\n            )\n\n            Spacer(modifier = Modifier.height(8.dp))\n\n            // 行为描述\n            Text(\n                text = result.description,\n                style = MaterialTheme.typography.bodyMedium,\n                color = MaterialTheme.colorScheme.onSurfaceVariant,\n                textAlign = TextAlign.Center,\n                modifier = Modifier.fillMaxWidth()\n            )\n\n            Spacer(modifier = Modifier.height(16.dp))\n\n            // 年龄标签\n            Surface(\n                color = MaterialTheme.colorScheme.primaryContainer,\n                shape = RoundedCornerShape(20.dp)\n            ) {\n                Text(\n                    text = \"适用年龄: ${result.ageRange}\",\n                    modifier = Modifier.padding(horizontal = 12.dp, vertical = 6.dp),\n                    style = MaterialTheme.typography.labelMedium\n                )\n            }\n\n            Divider(modifier = Modifier.padding(vertical = 16.dp))\n\n            // 分析部分\n            SectionCard(\n                title = \"📊 行为分析\",\n                content = result.analysis,\n                backgroundColor = MaterialTheme.colorScheme.errorContainer.copy(alpha = 0.3f)\n            )\n\n            Spacer(modifier = Modifier.height(12.dp))\n\n            // 建议部分\n            SectionCard(\n                title = \"💡 改正建议\",\n                content = result.suggestion,\n                backgroundColor = MaterialTheme.colorScheme.primaryContainer.copy(alpha = 0.3f)\n            )\n        }\n    }\n}\n\n@Composable\nfun ScoreCircle(score: Int, color: Color) {\n    Box(\n        modifier = Modifier\n            .size(120.dp)\n            .clip(CircleShape)\n            .background(color.copy(alpha = 0.2f)),\n        contentAlignment = Alignment.Center\n    ) {\n        Column(horizontalAlignment = Alignment.CenterHorizontally) {\n            Text(\n                text = score.toString(),\n                style = MaterialTheme.typography.displayLarge,\n                fontWeight = FontWeight.Bold,\n                color = color\n            )\n            Text(\n                text = \"分\",\n                style = MaterialTheme.typography.titleMedium,\n                color = color.copy(alpha = 0.7f)\n            )\n        }\n    }\n}\n\n@Composable\nfun SectionCard(\n    title: String,\n    content: String,\n    backgroundColor: Color\n) {\n    Card(\n        colors = CardDefaults.cardColors(containerColor = backgroundColor),\n        shape = RoundedCornerShape(12.dp)\n    ) {\n        Column(modifier = Modifier.padding(16.dp)) {\n            Text(\n                text = title,\n                style = MaterialTheme.typography.titleMedium,\n                fontWeight = FontWeight.Bold\n            )\n            Spacer(modifier = Modifier.height(8.dp))\n            Text(\n                text = content,\n                style = MaterialTheme.typography.bodyMedium,\n                lineHeight = 24.sp\n            )\n        }\n    }\n}\n","path":"/root/code/kid_app/app/src/main/java/com/kidscore/app/ui/screens/ScoreScreen.kt"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":54453,"output":1960,"cacheRead":13438,"cacheWrite":0,"totalTokens":69851,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1771489470058}}
