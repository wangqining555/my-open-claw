k_links[:20]\n    print(f\"同花顺: {len(stock_links)} stock news\")\nexcept Exception as e:\n    print(f\"同花顺 error: {e}\")\n\n# Print results\nprint(\"\\n=== Results ===\")\nfor source, news in news_sources.items():\n    print(f\"\\n{source}:\")\n    for title, url in news[:5]:\n        print(f\"  - {title[:50]}\")\nEOF","timeout":60}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":151316,"output":675,"cacheRead":13483,"cacheWrite":0,"totalTokens":165474,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1771430774523}}
