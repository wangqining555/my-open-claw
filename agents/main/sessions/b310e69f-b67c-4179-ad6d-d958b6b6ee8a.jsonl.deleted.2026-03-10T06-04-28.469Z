yicai.com/news/103053860.html\" target=\"_blank\">豆包：除夕豆包AI互动总数达19亿</a></h3>\n                <div class=\"news-meta\"><span class=\"source-tag source-yicai\">第一财经</span>2026-02-17</div>\n            </div>\n        </div>\n        \n        <div class=\"section\">\n            <div class=\"section-header\">\n                <h2 class=\"section-title\">🧠 人工智能板块 <span class=\"news-count\">(TOP 20)</span></h2>\n            </div>\n            \n            <div class=\"news-item\">\n                <h3 class=\"news-title\"><a href=\"https://www.yicai.com/news/103054335.html\" target=\"_blank\">AI进化速递 | 马斯克官宣Grok 4.2公测版上线</a></h3>\n                <div class=\"news-meta\"><span class=\"source-tag source-yicai\">第一财经</span><span class=\"tag tag-hot\">热门</span>2026-02-18</div>\n            </div>\n            \n            <div class=\"news-item\">\n                <h3 class=\"news-title\"><a href=\"https://www.yicai.com/news/103053982.html\" target=\"_blank\">宇树机器人刷新多个全球第一次</a></h3>\n                <div class=\"news-meta\"><span class=\"source-tag source-yicai\">第一财经</span>2026-02-17</div>\n            </div>\n            \n            <div class=\"news-item\">\n                <h3 class=\"news-title\"><a href=\"https://finance.eastmoney.com/a/202602183651456759.html\" target=\"_blank\">费城半导体指数上涨1.9%</a></h3>\n                <div class=\"news-meta\"><span class=\"source-tag source-eastmoney\">东方财富</span>2026-02-18</div>\n            </div>\n            \n            <div class=\"news-item\">\n                <h3 class=\"news-title\"><a href=\"https://finance.eastmoney.com/a/202602183651456759.html\" target=\"_blank\">谷歌推出Pixel10a智能手机</a></h3>\n                <div class=\"news-meta\"><span class=\"source-tag source-eastmoney\">东方财富</span>2026-02-18</div>\n            </div>\n            \n            <div class=\"news-item\">\n                <h3 class=\"news-title\"><a href=\"https://finance.eastmoney.com/a/202602183651456759.html\" target=\"_blank\">沙特Humain公司向xAI公司