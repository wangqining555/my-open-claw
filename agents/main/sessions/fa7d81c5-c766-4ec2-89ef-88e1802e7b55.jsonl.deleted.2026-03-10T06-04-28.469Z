{"type":"message","id":"ced4f344","parentId":"7dd0f56e","timestamp":"2026-02-22T02:28:43.474Z","message":{"role":"toolResult","toolCallId":"call_function_jfi9zsw8rnwf_1","toolName":"exec","content":[{"type":"text","text":"{\n  \"entries\": [\n    {\n      \"ts\": 1771550400036,\n      \"jobId\": \"31240d42-43aa-4b12-8a55-cdada12782a9\",\n      \"action\": \"finished\",\n      \"status\": \"error\",\n      \"error\": \"Error: cron: job execution timed out\",\n      \"runAtMs\": 1771549800007,\n      \"durationMs\": 600019,\n      \"nextRunAtMs\": 1771636200000\n    },\n    {\n      \"ts\": 1771576672226,\n      \"jobId\": \"31240d42-43aa-4b12-8a55-cdada12782a9\",\n      \"action\": \"finished\",\n      \"status\": \"error\",\n      \"error\": \"Error: Telegram send failed: chat not found (chat_id=qn_home@163.com). Likely: bot not started in DM, bot removed from group/channel, group migrated (new -100… id), or wrong bot token. Input was: \\\"qn_home@163.com\\\".\",\n      \"summary\": \"⚠️ 🛠️ Exec: `echo \\\"$(cat ~/.openclaw/workspace/a-stock-news-report-2026-02-20.html)\\\" | mail -s \\\"$(echo '=?UTF-8?B?6Z-p5a6M5paw5om/5Lya6aaZ5rivLSDIwMjYtYeS4i-eQhuWkqA=…` failed: mail: 1: not a header line\",\n      \"runAtMs\": 1771576066037,\n      \"durationMs\": 606181,\n      \"nextRunAtMs\": 1771636200000,\n      \"sessionId\": \"b310e69f-b67c-4179-ad6d-d958b6b6ee8a\",\n      \"sessionKey\": \"agent:main:cron:31240d42-43aa-4b12-8a55-cdada12782a9:run:b310e69f-b67c-4179-ad6d-d958b6b6ee8a\"\n    },\n    {\n      \"ts\": 1771579982471,\n      \"jobId\": \"31240d42-43aa-4b12-8a55-cdada12782a9\",\n      \"action\": \"finished\",\n      \"status\": \"error\",\n      \"error\": \"Error: Telegram send failed: chat not found (chat_id=qn_home@163.com). Likely: bot not started in DM, bot removed from group/channel, group migrated (new -100… id), or wrong bot token. Input was: \\\"qn_home@163.com\\\".\",\n      \"summary\": \"⚠️ 🛠️ Exec: `echo \\\"Test email\\\" | mail -v -s \\\"Test\\